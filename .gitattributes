* text=auto

# Keep Unity YAML assets consistently LF across Windows/macOS.
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf

# Source/config text files
*.cs text
*.shader text
*.cginc text
*.hlsl text
*.asmdef text
*.json text
*.xml text
*.yml text

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.psd binary
*.fbx binary
*.wav binary
*.mp3 binary
*.ogg binary
*.mp4 binary
*.mov binary

# Existing LFS rule
Assets/ithappy/Interior_Realistic/Render_Pipeline_Convert/*.unitypackage filter=lfs diff=lfs merge=lfs -text
